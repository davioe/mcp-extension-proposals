{
  "manifest_version": "0.1.0",
  "server": {
    "name": "linear-mcp-server",
    "version": "1.4.0",
    "mcp_spec_version": "2025-11-25",
    "description": "MCP server for Linear — issue tracking, project management, and cycle planning.",
    "homepage": "https://github.com/example/linear-mcp-server"
  },
  "auth": {
    "methods": ["oauth2_code", "bearer_token"],
    "scopes": [
      { "name": "read:issues", "description": "View issues, comments, and attachments", "grants": ["search_issues", "get_issue"] },
      { "name": "write:issues", "description": "Create and edit issues", "grants": ["create_issue", "update_issue", "bulk_update_issues"] },
      { "name": "read:projects", "description": "View projects and project metadata", "grants": ["list_projects", "get_project"] },
      { "name": "write:projects", "description": "Create and manage projects", "grants": ["create_project", "update_project"] },
      { "name": "read:cycles", "description": "View cycles and cycle progress", "grants": ["list_cycles", "get_cycle"] },
      { "name": "admin:workspace", "description": "Full workspace administration including destructive operations", "grants": ["delete_project", "manage_members", "manage_settings"] }
    ],
    "session_ttl_seconds": 3600
  },
  "tools": [
    {
      "name": "search_issues",
      "description": "Search Linear issues using filters or natural language queries.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query text" },
          "project": { "type": "string", "description": "Project identifier" },
          "status": { "type": "string", "enum": ["backlog", "todo", "in_progress", "in_review", "done", "cancelled"] },
          "assignee": { "type": "string" },
          "label": { "type": "string" },
          "priority": { "type": "integer", "description": "Priority level (0=none, 1=urgent, 2=high, 3=medium, 4=low)" },
          "limit": { "type": "integer", "default": 25, "maximum": 100 },
          "offset": { "type": "integer", "default": 0 }
        }
      },
      "cost": { "category": "free" },
      "latency": "instant",
      "idempotent": true,
      "requires_confirmation": false,
      "risk_level": "safe",
      "required_scopes": ["read:issues"],
      "supports_pagination": true
    },
    {
      "name": "create_issue",
      "description": "Create a new issue in Linear.",
      "input_schema": {
        "type": "object",
        "required": ["title", "team_id"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string", "description": "Markdown-formatted issue description" },
          "team_id": { "type": "string" },
          "project_id": { "type": "string" },
          "assignee_id": { "type": "string" },
          "priority": { "type": "integer", "description": "Priority level (0=none, 1=urgent, 2=high, 3=medium, 4=low)" },
          "labels": { "type": "array", "items": { "type": "string" } },
          "cycle_id": { "type": "string" }
        }
      },
      "cost": { "category": "free" },
      "latency": "instant",
      "idempotent": false,
      "requires_confirmation": false,
      "risk_level": "safe",
      "required_scopes": ["write:issues"]
    },
    {
      "name": "update_issue",
      "description": "Update an existing Linear issue's fields.",
      "input_schema": {
        "type": "object",
        "required": ["issue_id"],
        "properties": {
          "issue_id": { "type": "string", "description": "Issue identifier (e.g., 'ENG-123')" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["backlog", "todo", "in_progress", "in_review", "done", "cancelled"] },
          "assignee_id": { "type": "string" },
          "priority": { "type": "integer" },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      },
      "cost": { "category": "free" },
      "latency": "instant",
      "idempotent": true,
      "requires_confirmation": false,
      "risk_level": "reversible",
      "required_scopes": ["write:issues"]
    },
    {
      "name": "bulk_update_issues",
      "description": "Update multiple Linear issues at once. Applies the same changes to all specified issues.",
      "input_schema": {
        "type": "object",
        "required": ["issue_ids", "updates"],
        "properties": {
          "issue_ids": { "type": "array", "items": { "type": "string" }, "description": "List of issue identifiers to update" },
          "updates": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["backlog", "todo", "in_progress", "in_review", "done", "cancelled"] },
              "assignee_id": { "type": "string" },
              "priority": { "type": "integer" },
              "labels": { "type": "array", "items": { "type": "string" } },
              "cycle_id": { "type": "string" }
            }
          }
        }
      },
      "cost": { "category": "free" },
      "latency": "seconds",
      "idempotent": true,
      "requires_confirmation": true,
      "confirmation_message": "This will update N issues with the specified changes. Proceed?",
      "risk_level": "reversible",
      "required_scopes": ["write:issues"]
    },
    {
      "name": "delete_project",
      "description": "Permanently delete a Linear project and all associated data.",
      "input_schema": {
        "type": "object",
        "required": ["project_id"],
        "properties": {
          "project_id": { "type": "string", "description": "Project identifier" }
        }
      },
      "cost": { "category": "free" },
      "latency": "seconds",
      "idempotent": true,
      "requires_confirmation": true,
      "confirmation_message": "⚠️ DANGER: This will permanently delete the project and all associated data. This action CANNOT be undone. Proceed?",
      "risk_level": "destructive",
      "required_scopes": ["admin:workspace"]
    }
  ],
  "supported_extensions": [
    "streaming",
    "progress_notifications",
    "idempotency",
    "transactions",
    "session_state",
    "intent_hints",
    "structured_errors",
    "human_in_the_loop"
  ],
  "rate_limits": {
    "requests_per_minute": 100,
    "requests_per_day": 30000,
    "remaining": 29761,
    "resets_at": "2026-03-26T00:00:00Z"
  },
  "recommendations": [
    {
      "capability": "source_control",
      "server_name": "github-mcp-server",
      "registry_url": "https://mcp-registry.example.com/servers/github",
      "auth_flow": "oauth2_device",
      "match_confidence": "high"
    },
    {
      "capability": "design_collaboration",
      "server_name": "figma-mcp-server",
      "registry_url": "https://mcp-registry.example.com/servers/figma",
      "auth_flow": "oauth2_code",
      "match_confidence": "medium"
    }
  ]
}
